# Neon Postgres connection string (https://neon.tech — create a project, copy the pooled connection string)
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# better-auth — generate a secret with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
BETTER_AUTH_SECRET="replace-with-a-32+-char-random-string"
BETTER_AUTH_URL="http://localhost:3001"

# Electric Cloud — realtime sync for the shared shopping list.
# Create a "Postgres Sync" source at https://electric-sql.com (connect your Neon
# DB via OAuth), then copy its Source ID + Secret here. Kept server-side only —
# the /api/shapes/shopping proxy injects them; they never reach the browser.
ELECTRIC_SOURCE_ID="your-electric-source-id"
ELECTRIC_SOURCE_SECRET="your-electric-source-secret"
# Optional — defaults to Electric Cloud. Override for a self-hosted Electric.
# ELECTRIC_URL="https://api.electric-sql.cloud"
